# Problem Foundry Environment Settings

# Model Provider Settings
# Supported values: ollama, openai_compatible, lmstudio, vllm
MODEL_PROVIDER=ollama
MODEL_NAME=qwen2.5-coder:7b
API_BASE=http://localhost:11434
API_KEY=optional_key_if_needed

# Database Settings
# PostgreSQL (Default) or SQLite Fallback: sqlite+aiosqlite:///./foundry.db
DATABASE_URL=sqlite+aiosqlite:///./foundry.db

# ChromaDB Embeddings Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# Sandbox Verification Settings
MAX_EXECUTION_TIME_SECONDS=2
MAX_MEMORY_MB=512
NUM_STRESS_TESTS=10000

# Quality Gate Threshold
QUALITY_GATE_THRESHOLD=85.0
